<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MHTMLReader" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Main colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:colorBackground">@color/colorBackground</item>

        <!-- Standard texts -->
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
        <item name="android:textColorTertiary">@color/textTertiary</item>

        <!-- Surface and Floating -->
        <item name="colorBackgroundFloating">@color/colorSurface</item>
        
        <!-- Controls -->
        <item name="colorControlNormal">@color/colorStroke</item>
        <item name="colorControlActivated">@color/colorPrimary</item>
        <item name="colorControlHighlight">@color/colorSurfaceHighlight</item>
        
        <!-- Button styles -->
        <item name="android:buttonStyle">@style/Widget.MHTMLReader.Button</item>
        <item name="buttonStyle">@style/Widget.MHTMLReader.Button</item>
    </style>

    <style name="Widget.MHTMLReader.Button" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:background">@drawable/btn_primary_bg</item>
        <item name="android:minHeight">@dimen/home_action_min_height</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>