<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Removed debug input, buttons, progress, and list -->

    <ProgressBar
        android:id="@+id/reader_open_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-4dp"
        android:layout_marginBottom="-4dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/reader_pdf_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#EEE"
        android:visibility="gone">

        <Button
            android:id="@+id/reader_pdf_prev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_pdf_prev" />

        <TextView
            android:id="@+id/reader_pdf_page_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:gravity="center"
            android:textAppearance="?android:attr/textAppearanceSmall" />

        <Button
            android:id="@+id/reader_pdf_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_pdf_next" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/reader_pdf_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:background="#FFEFEFEF"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <WebView
            android:id="@+id/reader_web_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
            
        <TextView
            android:id="@+id/reader_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#80000000"
            android:textColor="#FFF"
            android:padding="8dp"
            android:visibility="gone"/>
    </FrameLayout>

</LinearLayout>
